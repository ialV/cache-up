# Required: Anthropic API key (can also be passed per-request via header)
ANTHROPIC_API_KEY=sk-ant-...

# Upstream Provider ("anthropic" (default), "openrouter", "generic")
# UPSTREAM_PROVIDER=anthropic

# If using openrouter, you can specify these optional headers:
# OPENROUTER_SITE_URL=https://your-site.com
# OPENROUTER_APP_NAME=CacheUp

# Force OpenRouter to use a specific provider (e.g., Anthropic) to maintain Cache isolation
# OPENROUTER_REQUIRE_PROVIDER=Anthropic

# Optional: Override Upstream API base URL (automatically set for openrouter if left blank)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: Server port (default: 8080)
# PORT=8080

# Optional: Log level (default: info)
# LOG_LEVEL=debug

# Optional: Minimum tokens to apply cache breakpoint (default: 1024)
# MIN_TOKENS_FOR_CACHE=1024
