# Required: Anthropic API key (can also be passed per-request via header)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override Anthropic API base URL
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: Server port (default: 8080)
# PORT=8080

# Optional: Log level (default: info)
# LOG_LEVEL=debug

# Optional: Minimum tokens to apply cache breakpoint (default: 1024)
# MIN_TOKENS_FOR_CACHE=1024
